NODE_ENV=development
PORT=3000
SESSION_STORE=auto
PORTAL_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-strong-random-secret
BACKEND_BASE_URL=http://localhost:8080
BACKEND_API_VERSION=1
BACKEND_AUTH_START_PATH=/auth/github
BACKEND_AUTH_EXCHANGE_PATH=/auth/github/callback
BACKEND_ME_PATH=/auth/me
BACKEND_LOGOUT_PATH=/auth/logout
BACKEND_REQUEST_TIMEOUT_MS=12000
DATABASE_URL=postgresql://user:password@host:5432/database
SESSION_TABLE_NAME=user_sessions
PG_SSL=true
